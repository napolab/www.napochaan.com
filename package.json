{
  "name": "www.napochaan.com",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "prepare": "husky && panda codegen",
    "panda": "panda",
    "fmt": "pnpm run fmt:oxfmt && pnpm run fmt:oxlint",
    "fmt:oxfmt": "oxfmt --write .",
    "fmt:oxlint": "oxlint --fix --ignore-pattern migrations --ignore-pattern .claude/worktrees --ignore-pattern src/app/\\(payload\\)/admin/importMap.js .",
    "lint": "pnpm run lint:oxfmt && pnpm run lint:oxlint",
    "lint:oxfmt": "oxfmt --check .",
    "lint:oxlint": "oxlint --ignore-pattern migrations --ignore-pattern .claude/worktrees --ignore-pattern src/app/\\(payload\\)/admin/importMap.js .",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "test": "vitest run",
    "preview": "CLOUDFLARE_ENV=staging opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "deploy:staging": "CLOUDFLARE_ENV=staging opennextjs-cloudflare build --env staging && CLOUDFLARE_ENV=staging opennextjs-cloudflare deploy --env staging && CLOUDFLARE_ENV=staging node scripts/bust-isr-cache.mjs",
    "deploy:database:staging": "CLOUDFLARE_ENV=staging payload migrate",
    "revalidate:isr": "node scripts/bust-isr-cache.mjs",
    "payload": "payload",
    "payload:migrate": "payload migrate",
    "payload:migrate:create": "payload migrate:create",
    "payload:generate-importmap": "payload generate:importmap",
    "payload:seed": "payload seed",
    "seed:export": "payload seed:export",
    "seed:import": "payload seed:import",
    "seed:import:prod": "payload seed:import:prod",
    "cf:types": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@hono/zod-validator": "^0.7.6",
    "@marsidev/react-turnstile": "^1.5.3",
    "@opennextjs/cloudflare": "1.18.0",
    "@payloadcms/db-d1-sqlite": "3.84.1",
    "@payloadcms/live-preview-react": "3.84.1",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/plugin-seo": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/storage-r2": "3.84.1",
    "@radix-ui/react-slot": "^1.2.4",
    "budoux": "^0.8.4",
    "dayjs": "^1.11.21",
    "durabcast": "^0.2.4",
    "fast-json-stable-stringify": "^2.1.0",
    "gsap": "^3.15.0",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "hono": "^4.12.23",
    "neverthrow": "^8.2.0",
    "next": "15.3.9",
    "payload": "3.84.1",
    "react": "^19.0.0",
    "react-aria-components": "^1.17.0",
    "react-dom": "^19.0.0",
    "reconnecting-websocket": "^4.4.0",
    "server-only": "^0.0.1",
    "shiki": "^4.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.5",
    "@pandacss/dev": "^1.11.1",
    "@svgr/webpack": "^8.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript/native-preview": "7.0.0-dev.20251229.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.2",
    "husky": "^9.1.7",
    "oxfmt": "^0.21.0",
    "oxlint": "^1.36.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.3",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18",
    "vitest-browser-react": "^2.1.0",
    "wrangler": "^4.78.0"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ],
    "overrides": {
      "undici": ">=7.24.0",
      "fast-xml-parser": ">=4.5.5",
      "lodash": ">=4.18.0",
      "drizzle-orm": ">=0.45.2",
      "dompurify": ">=3.3.2"
    }
  }
}
